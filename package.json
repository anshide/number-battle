{
  "name": "number-battle",
  "version": "1.0.0",
  "private": true,
  "description": "Real-time multiplayer Number Battle game",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --workspace=client",
    "build:vercel": "npm run build --workspace=@number-battle/shared && npm run build --workspace=@number-battle/client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
